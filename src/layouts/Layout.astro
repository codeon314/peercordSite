---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{title}</title>
        <link rel="icon" type="image/png" href="/peercord-logo.png" />
        <ClientRouter />
        
        <!-- Highlight.js for Syntax Highlighting -->
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css">
        <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    </head>
    <body>
        <header>
            <button class="hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="main-nav">
                <span class="line"></span>
                <span class="line"></span>
                <span class="line"></span>
            </button>
            <nav id="main-nav">
                <a href="/">Home</a>
                <a href="/features">Features</a>
                <a href="/download">Download</a>
                <a href="/faq">FAQ</a>
                <a href="/donate">Donate</a>
                <a href="https://git.churchofmalware.org/mastercodeon/Peercord" target="_blank" rel="noopener noreferrer">Source Code</a>
				<a href="/about">About</a>
            </nav>
        </header>

        <!-- This overlay will appear behind the menu to allow closing it by clicking outside -->
        <div class="overlay"></div>

        <slot />
    </body>
</html>
<style>
  /* --- DESKTOP STYLES (Default) --- */
  header {
    max-width: 800px;
    margin: 0 auto 2rem auto;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
  }

  nav {
    display: flex;
    gap: 1.5rem;
    font-size: 1.1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hamburger, .overlay {
    display: none;
  }

  /* --- MOBILE STYLES (Overrides the desktop styles) --- */
  @media (max-width: 768px) {
    header {
      border-bottom: none;
      padding-bottom: 0;
      margin-bottom: 1.5rem; /* Slightly less margin for mobile */
      max-width: 100%;
    }

    nav {
      position: fixed;
      top: 0;
      left: 0;
      width: fit-content; /* Make width fit the content */
      min-width: 200px; /* Optional: set a minimum width */
      height: 100%;
      background-color: var(--card-bg);
      flex-direction: column;
      justify-content: flex-start; /* Align items to the top */
      align-items: flex-start; /* Align items to the left */
      padding: 6rem 3rem 2rem 1.5rem; /* T, R, B, L padding */
      gap: 2rem;
      transform: translateX(-100%);
      transition: transform 0.3s ease-in-out;
      z-index: 1000;
      border-right: 1px solid var(--border-color);
    }

    nav.is-open {
      transform: translateX(0);
    }

    .hamburger {
      display: block;
      background: none;
      border: none;
      cursor: pointer;
      padding: 15px;
      position: relative; /* Changed for better control */
      z-index: 1001;
    }

    .hamburger .line {
      display: block;
      width: 25px;
      height: 3px;
      background-color: var(--text-color);
      margin: 5px 0;
      transition: transform 0.3s ease, opacity 0.3s ease;
    }

    /* Overlay for clicking outside to close */
    .overlay {
        display: block;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.5);
        z-index: 999; /* Below the nav, above the content */
        opacity: 0;
        pointer-events: none; /* Can't be clicked when hidden */
        transition: opacity 0.3s ease-in-out;
    }

    .overlay.is-open {
        opacity: 1;
        pointer-events: auto; /* Can be clicked when visible */
    }
  }
</style>

<script>
  function setupNav() {
    const hamburger = document.querySelector('.hamburger');
    const nav = document.querySelector('#main-nav');
    const overlay = document.querySelector('.overlay');
    const navLinks = nav.querySelectorAll('a');

    const toggleMenu = () => {
      const isOpen = nav.classList.toggle('is-open');
      overlay.classList.toggle('is-open', isOpen);
      hamburger.setAttribute('aria-expanded', isOpen);
    };

    if (hamburger && nav && overlay) {
      // Remove old listeners to prevent duplicates on ViewTransition navigation
      hamburger.replaceWith(hamburger.cloneNode(true));
      overlay.replaceWith(overlay.cloneNode(true));
      
      const newHamburger = document.querySelector('.hamburger');
      const newOverlay = document.querySelector('.overlay');

      newHamburger.addEventListener('click', toggleMenu);
      newOverlay.addEventListener('click', toggleMenu);
      
      navLinks.forEach(link => {
        link.addEventListener('click', () => {
            if (nav.classList.contains('is-open')) {
                toggleMenu();
            }
        });
      });
    }
  }

  function setupCodeBlocks() {
    const pres = document.querySelectorAll('pre');
    
    pres.forEach(pre => {
      // Prevent double-processing if ViewTransitions re-runs
      if (pre.parentElement.classList.contains('code-block-content')) return;

      const code = pre.querySelector('code');
      if (!code) return;

      // Extract language from class (e.g., "language-csharp")
      const langClass = Array.from(code.classList).find(c => c.startsWith('language-'));
      const lang = langClass ? langClass.replace('language-', '') : 'text';

      // Create UI Elements
      const wrapper = document.createElement('div');
      wrapper.className = 'code-block-wrapper';

      const header = document.createElement('div');
      header.className = 'code-block-header';
      header.title = "Click to collapse/expand";

      const langSpan = document.createElement('span');
      langSpan.className = 'code-lang';
      langSpan.textContent = lang;

      const actions = document.createElement('div');
      actions.className = 'code-actions';

      const copyBtn = document.createElement('button');
      copyBtn.className = 'code-btn';
      copyBtn.textContent = 'Copy';
      copyBtn.onclick = (e) => {
        e.stopPropagation(); // Prevent the header click event from firing
        navigator.clipboard.writeText(code.innerText).then(() => {
          copyBtn.textContent = 'Copied!';
          setTimeout(() => copyBtn.textContent = 'Copy', 2000);
        });
      };

      const collapseIcon = document.createElement('div');
      collapseIcon.className = 'collapse-icon';
      // SVG Chevron pointing UP (default open state)
      collapseIcon.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"></polyline></svg>`;
      
      // Grid container for smooth height animation
      const contentGrid = document.createElement('div');
      contentGrid.className = 'code-block-grid';

      const content = document.createElement('div');
      content.className = 'code-block-content';

      // Click header to toggle collapse
      header.onclick = () => {
        contentGrid.classList.toggle('is-collapsed');
        collapseIcon.classList.toggle('is-collapsed');
      };

      // Assemble
      actions.appendChild(copyBtn);
      actions.appendChild(collapseIcon);
      header.appendChild(langSpan);
      header.appendChild(actions);

      pre.parentNode.insertBefore(wrapper, pre);
      content.appendChild(pre);
      contentGrid.appendChild(content);
      wrapper.appendChild(header);
      wrapper.appendChild(contentGrid);

      // Apply Syntax Highlighting
      if (window.hljs) {
        hljs.highlightElement(code);
      }
    });
  }

  // Use Astro's built-in event for navigation to initialize scripts
  document.addEventListener('astro:page-load', () => {
    setupNav();
    setupCodeBlocks();
  });
</script>
--- START OF FILE src/pages/index.astro ---
---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Peercord | P2P Social Platform">
    <main>
        <section class="hero">
            <img src="/peercord-logo.png" alt="Peercord Logo" class="hero-logo" />
            <div class="hero-badge">
                <span class="pulse-dot"></span> Hyperswarm Network Active
            </div>
            <h1 class="glow-text">Peercord</h1>
            <h2 class="subtitle">Decentralized &middot; Encrypted &middot; Unstoppable</h2>
            <p class="hero-desc">
                Experience the next generation of social communication. A truly peer-to-peer platform powered by Hyperswarm and Pear Runtime. Own your data, host your own communities, and communicate without middlemen.
            </p>
            <div class="hero-actions">
                <a href="/download" class="cta-button primary">Download Peercord</a>
                <a href="/features" class="cta-button secondary">Explore Features</a>
                <a href="https://git.churchofmalware.org/mastercodeon/Peercord" target="_blank" rel="noopener noreferrer" class="cta-button secondary icon-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
                    Source Code
                </a>
            </div>
        </section>

        <div class="dashboard-grid" id="features">
            <!-- Feature Card 1 -->
            <div class="dashboard-card">
                <div class="card-header">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent-color)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><circle cx="4" cy="6" r="3"></circle><circle cx="20" cy="6" r="3"></circle><circle cx="4" cy="18" r="3"></circle><circle cx="20" cy="18" r="3"></circle><line x1="6.5" y1="7.5" x2="9.5" y2="10.5"></line><line x1="17.5" y1="7.5" x2="14.5" y2="10.5"></line><line x1="6.5" y1="16.5" x2="9.5" y2="13.5"></line><line x1="17.5" y1="16.5" x2="14.5" y2="13.5"></line></svg>
                    <h3>True P2P Architecture</h3>
                </div>
                <p class="feature-text">No central servers to go down or monitor your chats. Peercord uses the Hyperswarm DHT to connect you directly to your friends and communities.</p>
            </div>

            <!-- Feature Card 2 -->
            <div class="dashboard-card">
                <div class="card-header">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent-color)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                    <h3>Absolute Privacy</h3>
                </div>
                <p class="feature-text">Every message, voice call, and file transfer is encrypted end-to-end using xChaCha20-Poly1305. Your private keys never leave your device.</p>
            </div>

            <!-- Feature Card 3 -->
            <div class="dashboard-card">
                <div class="card-header">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent-color)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2v6h-6"></path><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><path d="M3 2v6h6"></path><path d="M21 12a9 9 0 1 0-9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"></path></svg>
                    <h3>Seamless OTA Updates</h3>
                </div>
                <p class="feature-text">Powered by Pear Runtime, Peercord updates itself automatically in the background via P2P seeding, ensuring you always have the latest features.</p>
            </div>

            <!-- Terminal Quick Info Card -->
            <div class="dashboard-card terminal-card">
                <div class="terminal-header">
                    <div class="terminal-dots">
                        <span class="dot red"></span>
                        <span class="dot yellow"></span>
                        <span class="dot green"></span>
                    </div>
                    <span class="terminal-title">node@peercord:~</span>
                </div>
                <div class="terminal-body">
                    <p><span class="prompt">&gt;</span> peercord --boot</p>
                    <p class="output">[Pear] Updater initialized. Current version: 1.0.0</p>
                    <p class="output">[P2P] Swarm flushed and announced.</p>
                    <p class="output">[Time Sync] Offset calculated: 14ms</p>
                    <p class="output success">🚀 Peercord UI successfully booted!</p>
                    <p><span class="prompt blink">_</span></p>
                </div>
            </div>
        </div>
    </main>
</Layout>

<style>
  /* --- Hero Section --- */
  .hero { 
    text-align: center; 
    padding: 3rem 0 4rem 0; 
    animation: fadeIn 1s ease-in-out; 
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-logo {
    width: 140px;
    height: auto;
    margin-bottom: 2rem;
    filter: drop-shadow(0 0 15px rgba(237, 66, 69, 0.4));
    animation: float 6s ease-in-out infinite;
  }
  
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-size: 0.85rem;
    color: #9CA3AF;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pulse-dot {
    width: 8px;
    height: 8px;
    background-color: var(--accent-color);
    border-radius: 50%;
    box-shadow: 0 0 8px var(--accent-color);
    animation: pulse 2s infinite;
  }

  .hero h1 { 
    font-size: 3.5rem; 
    margin: 0 0 0.5rem 0; 
    color: var(--text-color);
  }

  .glow-text {
    text-shadow: 0 0 20px rgba(237, 66, 69, 0.3);
  }

  .subtitle {
    font-size: 1.2rem;
    color: var(--accent-color);
    font-weight: normal;
    margin: 0 0 1.5rem 0;
  }

  .hero-desc { 
    font-size: 1.1rem; 
    color: #9CA3AF; 
    margin-bottom: 2.5rem; 
    max-width: 600px;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .cta-button { 
    padding: 0.8rem 1.8rem; 
    border-radius: 8px; 
    font-weight: bold; 
    transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease; 
  }

  .cta-button.primary {
    background-color: var(--accent-color); 
    color: #000000; 
  }

  .cta-button.primary:hover { 
    transform: translateY(-3px); 
    box-shadow: 0 5px 15px rgba(237, 66, 69, 0.4); 
    color: #000000; 
  }

  .cta-button.secondary {
    background-color: transparent;
    color: var(--text-color);
    border: 1px solid var(--border-color);
  }

  .cta-button.secondary:hover {
    background-color: var(--card-bg);
    border-color: var(--accent-color);
    transform: translateY(-3px);
  }

  .icon-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* --- Dashboard Grid --- */
  .dashboard-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
    animation: slideUp 0.8s ease-out forwards;
    opacity: 0;
    transform: translateY(20px);
  }

  .dashboard-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.8rem;
  }

  .card-header h3 {
    margin: 0;
    font-size: 1.2rem;
    color: var(--text-color);
  }

  .feature-text {
    color: #D1D5DB;
    margin: 0;
    line-height: 1.6;
  }

  /* --- Terminal Card Styling --- */
  .terminal-card {
    padding: 0;
    overflow: hidden;
    background-color: #050505;
  }

  .terminal-header {
    background-color: #111111;
    padding: 0.8rem 1rem;
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--border-color);
    position: relative;
  }

  .terminal-dots {
    display: flex;
    gap: 6px;
    position: absolute;
    left: 1rem;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot.red { background-color: #FF5F56; }
  .dot.yellow { background-color: #FFBD2E; }
  .dot.green { background-color: #27C93F; }

  .terminal-title {
    width: 100%;
    text-align: center;
    font-family: monospace;
    font-size: 0.85rem;
    color: #9CA3AF;
  }

  .terminal-body {
    padding: 1.5rem;
    font-family: 'Courier New', Courier, monospace;
    font-size: 0.95rem;
    color: #D1D5DB;
    line-height: 1.6;
  }

  .terminal-body p {
    margin: 0 0 0.5rem 0;
  }

  .prompt {
    color: var(--accent-color);
    font-weight: bold;
    margin-right: 0.5rem;
  }

  .output {
    color: #9CA3AF;
    margin-bottom: 0.5rem !important;
    padding-left: 1rem;
  }

  .output.success {
    color: #27C93F;
  }

  .blink {
    animation: blinker 1s linear infinite;
  }

  /* --- Animations --- */
  @keyframes fadeIn { 
    from { opacity: 0; } 
    to { opacity: 1; } 
  }
  
  @keyframes slideUp {
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(237, 66, 69, 0.7); }
    70% { box-shadow: 0 0 0 6px rgba(237, 66, 69, 0); }
    100% { box-shadow: 0 0 0 0 rgba(237, 66, 69, 0); }
  }

  @keyframes blinker {
    50% { opacity: 0; }
  }

  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
    100% { transform: translateY(0px); }
  }

  /* --- Mobile Adjustments --- */
  @media (max-width: 768px) {
    .hero { padding: 2rem 0; } 
    .hero-logo { width: 100px; }
    .hero h1 { font-size: 2.5rem; } 
    .subtitle { font-size: 1rem; }
    .hero-desc { font-size: 1rem; }
    .dashboard-grid { grid-template-columns: 1fr; }
  }
</style>