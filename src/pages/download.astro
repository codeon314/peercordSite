---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Download | Peercord">
    <main class="download-page">
        <div class="page-header">
            <h1 class="glow-text">Get Peercord</h1>
            <p class="subtitle">Available for major desktop operating systems.</p>
        </div>

        <div class="download-grid">
            <!-- Windows Download -->
            <div class="download-card">
                <div class="os-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
                </div>
                <h2>Windows</h2>
                <p>Windows 10 / 11 (64-bit)</p>
                <!-- PLACEHOLDER: Replace href with your actual Windows download link -->
                <a href="YOUR_WINDOWS_LINK_HERE" class="dl-btn primary">Download for Windows</a>
            </div>

            <!-- Linux Download -->
            <div class="download-card">
                <div class="os-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a2 2 0 0 0-2 2c0 1.1.9 2 2 2s2-.9 2-2a2 2 0 0 0-2-2Z"></path><path d="M10 22v-6.57"></path><path d="M14 22v-6.57"></path><path d="M12 11v4"></path><path d="M12 15a2.5 2.5 0 0 0 2.5-2.5V7.5a2.5 2.5 0 0 0-5 0v5A2.5 2.5 0 0 0 12 15Z"></path><path d="M6 11c0-1.7 1.3-3 3-3"></path><path d="M18 11c0-1.7-1.3-3-3-3"></path></svg>
                </div>
                <h2>Linux</h2>
                <p>Ubuntu 20.04+ / Debian / Fedora</p>
                <!-- PLACEHOLDER: Replace href with your actual Linux download link -->
                <a href="YOUR_LINUX_LINK_HERE" class="dl-btn secondary">Download for Linux</a>
            </div>

            <!-- macOS Download -->
            <div class="download-card">
                <div class="os-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20.94c1.5 0 2.75 1.06 4 1.06 3 0 6-8 6-12.22A4.91 4.91 0 0 0 17 5c-2.22 0-4 1.44-5 2-1-.56-2.78-2-5-2a4.9 4.9 0 0 0-5 4.78C2 14 5 22 8 22c1.25 0 2.5-1.06 4-1.06Z"></path><path d="M10 2c1 .5 2 2 2 5h-2c0-3-1-4-2-5Z"></path></svg>
                </div>
                <h2>macOS</h2>
                <p>macOS 11.0+ (Intel & Apple Silicon)</p>
                <button disabled class="dl-btn disabled">Coming Soon</button>
            </div>

            <!-- Android Download -->
            <div class="download-card">
                <div class="os-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line></svg>
                </div>
                <h2>Android</h2>
                <p>Android 10.0+</p>
                <button disabled class="dl-btn disabled">Coming Soon</button>
            </div>
        </div>

        <div class="sys-req">
            <h3>System Requirements</h3>
            <ul>
                <li><strong>Processor:</strong> 2.0 GHz dual-core or better</li>
                <li><strong>Memory:</strong> 4 GB RAM minimum (8 GB recommended for smooth WebRTC video calls)</li>
                <li><strong>Storage:</strong> 500 MB available space (Additional space required for cached P2P media and files)</li>
                <li><strong>Network:</strong> Broadband internet connection. A UPnP or NAT-PMP enabled router is highly recommended for optimal peer-to-peer connectivity.</li>
            </ul>
        </div>
    </main>
</Layout>

<style>
  .page-header {
    text-align: center;
    margin-bottom: 4rem;
    animation: fadeIn 0.8s ease-out;
  }

  .page-header h1 {
    font-size: 3rem;
    margin-bottom: 0.5rem;
    color: var(--text-color);
  }

  .glow-text {
    text-shadow: 0 0 20px rgba(237, 66, 69, 0.3);
  }

  .subtitle {
    font-size: 1.2rem;
    color: #9CA3AF;
  }

  .download-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    margin-bottom: 4rem;
    animation: slideUp 0.8s ease-out forwards;
    opacity: 0;
    transform: translateY(20px);
  }

  .download-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 2.5rem 1.5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .download-card:hover {
    transform: translateY(-5px);
    border-color: var(--accent-color);
  }

  .os-icon {
    color: var(--text-color);
    margin-bottom: 1.5rem;
  }

  .download-card h2 {
    margin: 0 0 0.5rem 0;
    font-size: 1.5rem;
  }

  .download-card p {
    color: #9CA3AF;
    font-size: 0.9rem;
    margin-bottom: 2rem;
    flex-grow: 1;
  }

  .dl-btn {
    display: inline-block;
    width: 100%;
    padding: 0.8rem 1rem;
    border-radius: 8px;
    font-weight: bold;
    text-align: center;
    box-sizing: border-box;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
    cursor: pointer;
  }

  .dl-btn.primary {
    background-color: var(--accent-color);
    color: #000000;
  }

  .dl-btn.primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(237, 66, 69, 0.4);
    color: #000000;
  }

  .dl-btn.secondary {
    background-color: transparent;
    color: var(--text-color);
    border: 1px solid var(--border-color);
  }

  .dl-btn.secondary:hover {
    background-color: var(--card-bg);
    border-color: var(--accent-color);
    transform: translateY(-2px);
  }

  .dl-btn.disabled {
    background-color: #1A1A1A;
    color: #6B7280;
    border: 1px solid #333333;
    cursor: not-allowed;
  }

  .dl-btn.disabled:hover {
    transform: none;
    box-shadow: none;
  }

  .sys-req {
    background-color: #050505;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 2rem;
    animation: fadeIn 1.2s ease-out;
  }

  .sys-req h3 {
    margin-top: 0;
    color: var(--accent-color);
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .sys-req ul {
    list-style-type: none;
    padding: 0;
    margin: 0;
  }

  .sys-req li {
    color: #D1D5DB;
    margin-bottom: 1rem;
    line-height: 1.5;
  }

  .sys-req li:last-child {
    margin-bottom: 0;
  }

  .sys-req strong {
    color: var(--text-color);
  }

  @keyframes fadeIn { 
    from { opacity: 0; } 
    to { opacity: 1; } 
  }
  
  @keyframes slideUp {
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .page-header h1 { font-size: 2.2rem; }
    .download-grid { grid-template-columns: 1fr; }
  }
</style>